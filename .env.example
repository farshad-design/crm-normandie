# ============================================
# CRM Immo Normandie — Variables d'environnement
# Copier ce fichier en .env.local et remplir
# ============================================

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJVOTRE_CLE_ANON
SUPABASE_SERVICE_ROLE_KEY=eyJVOTRE_SERVICE_ROLE

# Twilio SMS (https://twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+33XXXXXXXXX

# SMTP Email — Brevo (https://brevo.com)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=votre@email.fr
SMTP_PASS=VOTRE_MOT_DE_PASSE_BREVO
EMAIL_FROM="Votre Agence Normandie <contact@votre-agence.fr>"

# Géocodage — API Adresse gouv.fr (gratuit, pas de clé)
GEOCODING_API=https://api-adresse.data.gouv.fr/search/

# Zones à surveiller (codes postaux)
ZONES_CP=14000,14112,14123,14200,14320,14460,14650,14760
